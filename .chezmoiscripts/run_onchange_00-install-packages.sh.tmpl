#!/bin/sh

# {{ .packages }}

export PATH="$HOME/.local/bin:$PATH"

tmpdir=$(mktemp -d)

cd "$tmpdir"

curl -fsSL https://astral.sh/uv/install.sh | env UV_UNMANAGED_INSTALL="$tmpdir" sh
XONSH_SHOW_TRACEBACK=true MISE_EXPERIMENTAL=true ./uvx --with pydantic xonsh {{ .chezmoi.sourceDir }}/.chezmoiscripts/.install-packages.xsh

rm -rf "$tmpdir"

printf "\nPlease restart your shell.\n"
