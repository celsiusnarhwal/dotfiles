#!/usr/bin/env xonsh

import sys

if len(sys.argv) > 1 and sys.argv[1] == "--install":
	if ![@error_ignore gum confirm "Reinstall packages?"]:
		echo $(chezmoi execute-template -f $(chezmoi source-path)/.chezmoiscripts/run_onchange_00_install_packages.sh.tmpl) | sh

	exit()

$EDITOR $(chezmoi source-path)/.chezmoidata/packages.yml
