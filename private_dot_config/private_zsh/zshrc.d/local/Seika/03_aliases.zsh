alias compose-environ="dotenvx run -qo -f ${CONFIG_DIR}/.env"
alias lzd="lazydocker"
alias compose="compose-environ -- docker compose -f $COMPOSE_FILE"
alias caddyfile="$EDITOR ${CONFIG_DIR}/caddy/Caddyfile"
alias dx="docker exec"
alias c="compose"
alias cr="compose restart"
alias cu="compose up -d"
alias cfr="compose up -d --force-recreate"
alias cf="compose-file"
alias ce="compose-env"
alias speedtest="docker exec speedtest speedtest"
